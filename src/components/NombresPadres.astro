---
// src/components/NombresPadres.astro
---

<section class="w-full flex flex-col items-center">

    <!-- Cinta arriba — full width, se acerca al texto con margen negativo -->
    <div id="cinta-arriba" class="w-full" style="margin-bottom: -38%;">
        <img src="/imagenes/cinta.png" alt="" class="w-full object-contain block" />
    </div>

    <!-- Texto encima del espacio interior de la cinta -->
    <div id="contenido-padres" class="relative z-10 text-center w-full px-8">

        <p class="font-charm text-xl" style="color: #8B7355; line-height: 1.5;">
            En compañía de mis<br/>queridos padres y padrinos
        </p>

        <p class="font-charm text-xl font-bold mt-3" style="color: #8B7355;">Mis Padres</p>
        <p class="font-charm text-xl" style="color: #8B1A3D; line-height: 1.4;">Juan Carlos Sejas</p>
        <p class="font-charm text-xl" style="color: #8B1A3D; line-height: 1.4;">Libaneza Aramayo</p>

        <div class="flex items-center justify-center gap-3 my-2">
            <div style="width: 50px; height: 1px; background: linear-gradient(to right, transparent, #8B735588);"></div>
            <div style="width: 5px; height: 5px; border-radius: 50%; background: #8B7355; opacity: 0.8;"></div>
            <div style="width: 50px; height: 1px; background: linear-gradient(to left, transparent, #8B735588);"></div>
        </div>

        <p class="font-charm text-xl font-bold" style="color: #8B7355;">Mis Padrinos</p>
        <p class="font-charm text-xl" style="color: #8B1A3D; line-height: 1.4;">Ana Paola Sejas</p>
        <p class="font-charm text-xl" style="color: #8B1A3D; line-height: 1.4;">Pedro Salvatierra</p>
    </div>

    <!-- Cinta abajo — invertida, sube hacia el texto -->
    <div id="cinta-abajo" class="w-full" style="margin-top: -38%;">
        <img src="/imagenes/cinta.png" alt="" class="w-full object-contain block" style="transform: scaleY(-1);" />
    </div>

</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {

        gsap.set("#cinta-arriba",     { opacity: 0, y: -20 });
        gsap.set("#cinta-abajo",      { opacity: 0, y:  20 });
        gsap.set("#contenido-padres", { opacity: 0 });

        ScrollTrigger.create({
            trigger: "section",
            start: "top 80%",

            onEnter: () => {
                const tl = gsap.timeline();
                tl
                    .to("#cinta-arriba",     { opacity: 1, y: 0, duration: 1,   ease: "power2.out" }, 0)
                    .to("#cinta-abajo",      { opacity: 1, y: 0, duration: 1,   ease: "power2.out" }, 0.2)
                    .to("#contenido-padres", { opacity: 1,        duration: 1.1, ease: "power2.out" }, 0.5);
            },

            onLeaveBack: () => {
                gsap.to(["#cinta-arriba", "#cinta-abajo", "#contenido-padres"], {
                    opacity: 0, duration: 0.4, ease: "power2.in",
                });
            },
        });
    });
</script>
