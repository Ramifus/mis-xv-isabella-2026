---
// ContadorRegresivo.astro
---

<section class="py-8 px-6">
    <div class="max-w-md mx-auto">

        <div class="relative" id="cuenta-regresiva">

            <!-- Moño izquierdo — recto -->
            <img
                src="/imagenes/mono.png"
                alt=""
                id="mono-izq"
                class="absolute pointer-events-none"
                style="width: 52px; top: -22px; left: 8px; z-index: 10;"
            />

            <!-- Moño derecho — mono2, rotado a la derecha -->
            <img
                src="/imagenes/mono2.png"
                alt=""
                id="mono-der"
                class="absolute pointer-events-none"
                style="width: 52px; top: -22px; right: 8px; z-index: 10; transform: rotate(15deg);"
            />

            <!-- Etiqueta "Faltan" centrada arriba -->
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 z-10" id="texto-faltan">
                <div class="px-6 py-1.5 rounded-full shadow-md" style="background: #d0727d;">
                    <p class="font-charm text-sm md:text-base tracking-wide text-white">Faltan</p>
                </div>
            </div>

            <!-- Caja principal -->
            <div
                class="bg-white rounded-2xl pt-8 pb-5 px-6 shadow-sm"
                style="border: 2px solid #d0727d;"
            >
                <!-- Línea decorativa superior -->
                <div class="flex items-center justify-center gap-2 mb-4">
                    <div style="width: 40px; height: 1px; background: linear-gradient(to right, transparent, #C9A96E);"></div>
                    <div style="width: 5px; height: 5px; border-radius: 50%; background: #C9A96E; opacity: 0.8;"></div>
                    <div style="width: 40px; height: 1px; background: linear-gradient(to left, transparent, #C9A96E);"></div>
                </div>

                <div class="grid grid-cols-4 gap-3">

                    <!-- DÍAS -->
                    <div class="text-center">
                        <p id="dias" class="font-crimson text-4xl md:text-5xl font-bold mb-1" style="color: #d0727d;">00</p>
                        <p class="font-charm text-xs md:text-sm uppercase tracking-widest" style="color: #C9A96E;">Días</p>
                    </div>

                    <!-- HORAS -->
                    <div class="text-center">
                        <p id="horas" class="font-crimson text-4xl md:text-5xl font-bold mb-1" style="color: #d0727d;">00</p>
                        <p class="font-charm text-xs md:text-sm uppercase tracking-widest" style="color: #C9A96E;">Hrs</p>
                    </div>

                    <!-- MINUTOS -->
                    <div class="text-center">
                        <p id="minutos" class="font-crimson text-4xl md:text-5xl font-bold mb-1" style="color: #d0727d;">00</p>
                        <p class="font-charm text-xs md:text-sm uppercase tracking-widest" style="color: #C9A96E;">Mins</p>
                    </div>

                    <!-- SEGUNDOS -->
                    <div class="text-center">
                        <p id="segundos" class="font-crimson text-4xl md:text-5xl font-bold mb-1" style="color: #d0727d;">00</p>
                        <p class="font-charm text-xs md:text-sm uppercase tracking-widest" style="color: #C9A96E;">Segs</p>
                    </div>

                </div>

                <!-- Línea decorativa inferior -->
                <div class="flex items-center justify-center gap-2 mt-4">
                    <div style="width: 40px; height: 1px; background: linear-gradient(to right, transparent, #C9A96E);"></div>
                    <div style="width: 5px; height: 5px; border-radius: 50%; background: #C9A96E; opacity: 0.8;"></div>
                    <div style="width: 40px; height: 1px; background: linear-gradient(to left, transparent, #C9A96E);"></div>
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const FECHA_EVENTO = { año: 2026, mes: 6, dia: 20, hora: 19, minuto: 0 };

    const initContador = () => {

        gsap.set("#cuenta-regresiva", { opacity: 0, y: 20, scale: 0.95 });
        gsap.set("#mono-izq", { opacity: 0, x: -15, rotation: 0 });
        gsap.set("#mono-der", { opacity: 0, x:  15, rotation: 15 });

        ScrollTrigger.create({
            trigger: "#cuenta-regresiva",
            start: "top 85%",

            onEnter: () => {
                const tl = gsap.timeline();
                tl
                    .to("#cuenta-regresiva", { opacity: 1, y: 0, scale: 1, duration: 0.9, ease: "back.out(1.4)" })
                    .to("#mono-izq", { opacity: 1, x: 0, duration: 0.7, ease: "back.out(1.6)" }, 0.3)
                    .to("#mono-der", { opacity: 1, x: 0, duration: 0.7, ease: "back.out(1.6)" }, 0.4);

                // balanceo suave de los moños
                gsap.to("#mono-izq", { rotation: -6, duration: 2.5, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 1.2, transformOrigin: "center top" });
                gsap.to("#mono-der", { rotation: 20, duration: 2.8, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 1.4, transformOrigin: "center top" });
            },

            onLeaveBack: () => {
                gsap.killTweensOf(["#mono-izq", "#mono-der"]);
                gsap.to("#cuenta-regresiva", { opacity: 0, y: 20, scale: 0.95, duration: 0.5, ease: "power2.in" });
                gsap.to(["#mono-izq", "#mono-der"], { opacity: 0, duration: 0.4 });
            },
        });

        // Cuenta regresiva
        const fechaEvento = new Date(
            FECHA_EVENTO.año, FECHA_EVENTO.mes - 1, FECHA_EVENTO.dia,
            FECHA_EVENTO.hora, FECHA_EVENTO.minuto, 0
        ).getTime();

        function actualizar() {
            const diff = fechaEvento - new Date().getTime();
            if (diff > 0) {
                const d = Math.floor(diff / 86400000);
                const h = Math.floor((diff % 86400000) / 3600000);
                const m = Math.floor((diff % 3600000) / 60000);
                const s = Math.floor((diff % 60000) / 1000);
                document.getElementById("dias")!.textContent     = String(d).padStart(2,"0");
                document.getElementById("horas")!.textContent    = String(h).padStart(2,"0");
                document.getElementById("minutos")!.textContent  = String(m).padStart(2,"0");
                document.getElementById("segundos")!.textContent = String(s).padStart(2,"0");
            }
        }

        actualizar();
        setInterval(actualizar, 1000);
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initContador);
    } else {
        initContador();
    }

    document.addEventListener("astro:page-load", initContador);
</script>
