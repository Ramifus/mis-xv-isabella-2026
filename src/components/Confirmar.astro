---
// Confirmar.astro
---

<section class="relative w-full py-8 px-6 overflow-hidden">

    <!-- Separador arriba — borde a borde -->
    <div class="w-full mb-6" style="margin-left: -1.5rem; width: calc(100% + 3rem);">
        <img src="/imagenes/separador.png" alt="" class="w-full object-contain block" />
    </div>


<div class="max-w-sm mx-auto relative z-10 text-center" id="contenedor-confirmar">

        <!-- Moños flanqueando título -->
        <div class="flex items-center justify-center gap-3 mb-3">
            <img src="/imagenes/mono2.png" alt="" id="mono-conf-izq"
                style="width: 50px; object-fit: contain;" />
            <h3 class="font-crimson uppercase tracking-[0.2em] text-xl font-semibold"
                style="color: #C9A96E;">
                Confirmar<br/>Asistencia
            </h3>
            <img src="/imagenes/mono2.png" alt="" id="mono-conf-der"
                style="width: 50px; object-fit: contain;" />
        </div>

        <!-- Línea decorativa -->
        <div class="flex items-center justify-center gap-3 mb-5">
            <div style="width: 50px; height: 1px; background: linear-gradient(to right, transparent, #C9A96E);"></div>
            <div style="width: 5px; height: 5px; border-radius: 50%; background: #C9A96E; opacity: 0.8;"></div>
            <div style="width: 50px; height: 1px; background: linear-gradient(to left, transparent, #C9A96E);"></div>
        </div>

        <!-- Mensaje dedicatoria -->
        <div id="mensaje-despedida">
            <p class="font-charm text-xl leading-relaxed mb-5" style="color: #d0727d;">
                Con la bendición de Dios y el amor de toda mi familia, me siento muy feliz de llegar a este momento tan especial de mi vida. Quisiera compartir este comienzo de esta bella etapa junto a todos ustedes.
            </p>
        </div>

        <!-- Corazón decorativo -->
        <div class="flex items-center justify-center gap-3 mb-5" id="linea-decorativa">
            <div style="width: 50px; height: 1px; background: linear-gradient(to right, transparent, #d0727d);"></div>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#d0727d">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
            <div style="width: 50px; height: 1px; background: linear-gradient(to left, transparent, #d0727d);"></div>
        </div>

        <!-- Texto confirmar -->
        <p class="font-charm text-xl leading-relaxed mb-5" style="color: #d0727d;" id="texto-confirmar">
            Tu presencia es muy importante para mí. Por favor confirma tu asistencia para compartir juntos este día tan especial.
        </p>

        <!-- Botón WhatsApp -->
        <div class="flex justify-center mb-6" id="boton-confirmar">
            <a href="https://wa.me/59168814798?text=Me%20complace%20confirmar%20mi%20asistencia%20para%20los%2015%20a%C3%B1os%20de%20Isabella.%20Nos%20vemos%20el%20s%C3%A1bado%2020%20de%20junio.%20%C2%A1Estar%C3%A9%20sin%20falta!"
                target="_blank" rel="noopener noreferrer"
                class="font-charm text-xl text-white rounded-xl px-6 py-2.5 shadow-md transition-all duration-300 hover:opacity-90 active:scale-95 flex items-center gap-2"
                style="background: #d0727d;">
                <!-- WhatsApp icon -->
                <svg class="w-5 h-5" fill="white" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Confirmar asistencia
            </a>
        </div>

        <!-- Mensaje final -->
        <p class="font-great-vibes text-4xl" style="color: #d0727d;" id="mensaje-final">
            ¡Los espero con mucho cariño!
        </p>

    </div>

</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {

            gsap.set("#contenedor-confirmar", { opacity: 0, y: 25 });
            gsap.set("#mono-conf-izq",  { opacity: 0, x: -15 });
            gsap.set("#mono-conf-der",  { opacity: 0, x: 15, scaleX: -1 });

            ScrollTrigger.create({
                trigger: "#contenedor-confirmar",
                start: "top 80%",
                onEnter: () => {
                    const tl = gsap.timeline();
                    tl
                        .to("#contenedor-confirmar",{ opacity: 1, y: 0,   duration: 1.1, ease: "power2.out" }, 0.2)
                        .to("#mono-conf-izq",        { opacity: 1, x: 0,   duration: 0.8, ease: "back.out(1.5)" }, 0.5)
                        .to("#mono-conf-der",        { opacity: 1, x: 0, scaleX: -1, duration: 0.8, ease: "back.out(1.5)" }, 0.6);

                    gsap.to("#mono-conf-izq", { rotation: -7, duration: 2.5, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 1.2, transformOrigin: "center top" });
                    gsap.to("#mono-conf-der", { rotation: -7, scaleX: -1, duration: 2.8, repeat: -1, yoyo: true, ease: "sine.inOut", delay: 1.4, transformOrigin: "center top" });
                    gsap.to("#linea-decorativa svg", { scale: 1.2, duration: 1.5, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1 });
                    gsap.to("#boton-confirmar a", { y: -3, duration: 2, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 1.5 });
                },
                onLeaveBack: () => {
                    gsap.killTweensOf(["#mono-conf-izq","#mono-conf-der","#linea-decorativa svg","#boton-confirmar a"]);
                    gsap.to(["#contenedor-confirmar","#mono-conf-izq","#mono-conf-der"], {
                        opacity: 0, duration: 0.4, ease: "power2.in",
                    });
                },
            });
        });
    }
</script>
