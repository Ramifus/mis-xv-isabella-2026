---
// src/components/NombresFlores.astro
---

<section class="relative text-black w-full overflow-x-hidden">
  <div
    class="relative w-full overflow-hidden"
    id="flores-arriba"
    style="opacity: 1 !important;"
  >
    <img
      src="/imagenes/floresarriba.png"
      alt="Flores decorativas"
      class="w-full h-auto object-cover object-center block"
      style="opacity: 1 !important;"
    />

    <div
      class="absolute left-1/2 transform -translate-x-1/2 top-[100px] sm:top-16 md:top-12 lg:top-8 xl:top-4 z-50"
      id="corona"
    >
      <img
        src="/imagenes/corona.png"
        alt="Corona de quinceañera"
        class="w-24 h-auto sm:w-24 sm:h-24 md:w-28 md:h-28 lg:w-32 lg:h-32 xl:w-36 xl:h-36 object-contain mx-auto"
      />
    </div>
  </div>

  <div class="relative w-full sm:pt-40 md:pt-48 overflow-hidden px-4">
    <div class="flex justify-center w-full">
      <div class="text-center z-10 max-w-4xl w-full">
        <div
          class="relative text-center z-30 mb-8 w-full"
          id="titulo-container"
        >
          <h1
            class="font-crimson text-2xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl text-[#8B1A3D] font-bold tracking-wider"
            id="titulo"
          >
            MIS XV AÑOS
          </h1>
        </div>

        <div
          class="flex items-center justify-center gap-6 sm:gap-10 md:gap-16 mb-8 w-full"
          id="nombre-container"
        >
          <div id="mariposa-izq" class="flex-shrink-0">
            <img
              src="/imagenes/mono2.png"
              alt="moño izquierdo"
              class="w-20 h-auto object-contain"
            />
          </div>

          <h2
            class="font-great-vibes text-6xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-[#8B1A3D] tracking-wide whitespace-nowrap leading-tight"
            id="nombre-typewriter"
          >
          </h2>

          <div id="mariposa-der" class="flex-shrink-0">
            <img
              src="/imagenes/mono2.png"
              alt="moño derecho"
              class="w-20 h-auto object-contain scale-x-[-1]"
            />
          </div>
        </div>

        <div class="relative w-full overflow-visible" id="foto-container">
          <div
            id="flores-foto-izq"
            class="absolute -left-4 sm:left-0 top-32 sm:top-24 md:top-20 lg:top-16 flex-shrink-0 z-30"
          >
            <img
              src="/imagenes/florlateral.png"
              alt="Flores izquierda"
              class="w-12 h-auto sm:w-14 md:w-16 lg:w-20 object-contain"
            />
          </div>

          <div
            id="flores-foto-der"
            class="absolute -right-4 sm:right-0 top-32 sm:top-24 md:top-20 lg:top-16 flex-shrink-0 z-30"
          >
            <img
              src="/imagenes/florlateral.png"
              alt="Flores derecha"
              class="w-12 h-auto sm:w-14 md:w-16 lg:w-20 object-contain scale-x-[-1]"
            />
          </div>

          <div class="relative flex justify-center">
            <img
              src="/imagenes/quince.png"
              alt="Foto de quinceañera"
              class="w-full max-w-[65vw] h-auto sm:max-w-[55vw] md:max-w-[45vw] lg:max-w-[35vw] xl:max-w-[30vw] object-contain"
              id="foto-quinceañera"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 🎵 BOTÓN FLOTANTE DE MÚSICA -->
  <div
    class="fixed bottom-6 right-6 z-[9999]"
    id="boton-musica-flotante"
    style="opacity: 0;"
  >
    <button
      id="toggle-musica-global"
      class="group relative w-14 h-14 rounded-full shadow-lg flex items-center justify-center transition-all duration-200 hover:scale-110 active:scale-95 border border-[#f4b8c8]/60"
      style="background: rgba(255,255,255,0.85); backdrop-filter: blur(8px);"
      aria-label="Controlar música"
    >
      <!-- ICONO PAUSE - inicia oculto -->
      <svg
        id="icono-pause-global"
        class="w-6 h-6 hidden relative z-10"
        style="color: #6B0F2A;"
        fill="currentColor"
        viewBox="0 0 20 20"
      >
        <path
          d="M5.5 3.5A1.5 1.5 0 017 2h1a1.5 1.5 0 011.5 1.5v13A1.5 1.5 0 018 18H7a1.5 1.5 0 01-1.5-1.5v-13zm7 0A1.5 1.5 0 0114 2h1a1.5 1.5 0 011.5 1.5v13a1.5 1.5 0 01-1.5 1.5h-1a1.5 1.5 0 01-1.5-1.5v-13z"
        ></path>
      </svg>

      <!-- ICONO PLAY - inicia visible -->
      <svg
        id="icono-play-global"
        class="w-6 h-6 relative z-10"
        style="color: #6B0F2A;"
        fill="currentColor"
        viewBox="0 0 20 20"
      >
        <path
          d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"
        ></path>
      </svg>

      <!-- Onda de sonido - inicia oculta -->
      <div
        class="absolute -inset-2 rounded-full border-2 border-[#f4b8c8]/60 hidden"
        id="onda-sonido"
      >
      </div>
    </button>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {

    // ── Estado inicial ────────────────────────────────────────
    gsap.set("#corona",         { opacity: 0, scale: 0.5 });
    gsap.set("#titulo",         { opacity: 0, y: 30 });
    gsap.set("#mariposa-izq",   { opacity: 0, x: -30, scale: 0.85 });
    gsap.set("#mariposa-der",   { opacity: 0, x: 30,  scale: 0.85 });
    gsap.set("#flores-foto-izq",{ opacity: 0, x: -80 });
    gsap.set("#flores-foto-der",{ opacity: 0, x:  80 });
    gsap.set("#foto-container", { opacity: 0, scale: 0.9, y: 25 });
    gsap.set("#nombre-container", { opacity: 0 });

    function nombreCascadaElegante() {
      const linea1 = "Isabella";
      const contenedor = document.getElementById("nombre-typewriter");
      if (!contenedor) return;
      const letras = linea1.split("").map((letra, i) =>
        `<span class="letra-cascada" style="--i:${i}; opacity:0; display:inline-block; transform:translateY(30px) scale(0.8); filter:blur(2px);">${letra}</span>`
      ).join("");
      contenedor.innerHTML = `<span class="block">${letras}</span>`;
      gsap.to(".letra-cascada", {
        opacity: 1, y: 0, scale: 1, filter: "blur(0px)",
        duration: 0.8, ease: "back.out(1.6)",
        stagger: { each: 0.12, from: "start" },
      });
    }

    // ── ScrollTrigger ─────────────────────────────────────────
    ScrollTrigger.create({
      trigger: "#flores-arriba",
      start: "top 90%",

      onEnter: () => {
        const tl = gsap.timeline();
        tl
          .to("#corona",          { opacity: 1, scale: 1, duration: 1.1, ease: "back.out(1.3)" }, 0)
          .to("#titulo",          { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" }, 0.3)
          .to("#mariposa-izq",    { opacity: 1, x: 0, scale: 1, duration: 1, ease: "back.out(1.4)" }, 0.4)
          .to("#mariposa-der",    { opacity: 1, x: 0, scale: 1, duration: 1, ease: "back.out(1.4)" }, 0.5)
          .to("#nombre-container",{ opacity: 1, duration: 0.1 }, 0.6)
          .to("#flores-foto-izq", { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" }, 0.5)
          .to("#flores-foto-der", { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" }, 0.6)
          .to("#foto-container",  { opacity: 1, scale: 1, y: 0, duration: 1.1, ease: "power2.out" }, 0.7);

        tl.add(() => {
          nombreCascadaElegante();
          gsap.to("#mariposa-izq", { rotation: -8, duration: 3, ease: "sine.inOut", yoyo: true, repeat: -1, transformOrigin: "center top" });
          gsap.to("#mariposa-der", { rotation:  8, duration: 3, ease: "sine.inOut", yoyo: true, repeat: -1, transformOrigin: "center top" });
        }, 0.8);
      },

      onLeaveBack: () => {
        gsap.killTweensOf(["#mariposa-izq","#mariposa-der"]);
        gsap.set("#corona",          { opacity: 0, scale: 0.5 });
        gsap.set("#titulo",          { opacity: 0, y: 30 });
        gsap.set("#mariposa-izq",    { opacity: 0, x: -30, scale: 0.85, rotation: 0 });
        gsap.set("#mariposa-der",    { opacity: 0, x:  30, scale: 0.85, rotation: 0 });
        gsap.set("#flores-foto-izq", { opacity: 0, x: -80 });
        gsap.set("#flores-foto-der", { opacity: 0, x:  80 });
        gsap.set("#foto-container",  { opacity: 0, scale: 0.9, y: 25 });
        gsap.set("#nombre-container",{ opacity: 0 });
        const contenedor = document.getElementById("nombre-typewriter");
        if (contenedor) contenedor.innerHTML = "";
      },
    });

    // ── Botón flotante de música (solo una vez) ───────────────
    gsap.fromTo(
      "#boton-musica-flotante",
      { opacity: 0, scale: 0, rotation: -180 },
      { opacity: 1, scale: 1, rotation: 0, duration: 0.8, ease: "back.out(1.7)", delay: 1.5 },
    );

    const botonToggle = document.getElementById("toggle-musica-global");
    const iconoPlay = document.getElementById("icono-play-global");
    const iconoPause = document.getElementById("icono-pause-global");
    const ondaSonido = document.getElementById("onda-sonido");

    // Sincronizar estado visual al cargar (por si la música ya venía corriendo desde Portada)
    function sincronizarEstadoInicial() {
      const estadoActual = (window as any).estaReproduciendoGlobal;
      if (estadoActual) {
        iconoPlay?.classList.add("hidden");
        iconoPause?.classList.remove("hidden");
        ondaSonido?.classList.remove("hidden");
      }
    }

    sincronizarEstadoInicial();

    // Portada dispara este evento cuando el invitado toca el sobre
    window.addEventListener("musica-iniciada", () => {
      iconoPlay?.classList.add("hidden");
      iconoPause?.classList.remove("hidden");
      ondaSonido?.classList.remove("hidden");
    });

    botonToggle?.addEventListener("click", () => {
      const audioActual = (window as any).audioGlobal;
      const estadoActual = (window as any).estaReproduciendoGlobal;

      if (estadoActual && audioActual) {
        audioActual.pause();
        (window as any).estaReproduciendoGlobal = false;
        iconoPause?.classList.add("hidden");
        iconoPlay?.classList.remove("hidden");
        ondaSonido?.classList.add("hidden");
        console.log("⏸️ Música pausada");
      } else if (audioActual) {
        audioActual.play().catch((error: any) => {
          console.log("❌ Error al reproducir:", error);
        });
        (window as any).estaReproduciendoGlobal = true;
        iconoPlay?.classList.add("hidden");
        iconoPause?.classList.remove("hidden");
        ondaSonido?.classList.remove("hidden");
        console.log("▶️ Música reproduciéndose");
      }
    });

    console.log("Animaciones listas!");
  });
</script>

<style>
  #flores-arriba,
  #flores-arriba img {
    opacity: 1 !important;
  }

  .letra-cascada {
    transition: all 0.3s ease;
    will-change: transform, opacity, filter;
    position: relative;
  }

  .letra-cascada:hover {
    transform: translateY(-3px) scale(1.05) !important;
    text-shadow: 0 0 12px rgba(78, 104, 75, 0.5) !important;
  }

  @keyframes ping-slow {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    75%,
    100% {
      transform: scale(1.3);
      opacity: 0;
    }
  }

  @keyframes pulse-subtle {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  #onda-sonido {
    animation: ping-slow 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  #boton-musica-flotante button {
    animation: pulse-subtle 3s ease-in-out infinite;
  }

  #boton-musica-flotante button:hover {
    animation: none;
  }
</style>
