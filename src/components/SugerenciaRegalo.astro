---
// SugerenciaRegalo.astro
---

<section class="relative w-full py-8 px-6 overflow-hidden">
    <!-- Separador arriba — borde a borde -->
    <div
        class="w-full mb-6"
        style="margin-left: -1.5rem; margin-right: -1.5rem; width: calc(100% + 3rem);"
    >
        <img
            src="/imagenes/separador.png"
            alt=""
            class="w-full object-contain block"
        />
    </div>

    <!-- Flores pegadas a los bordes -->
    <img
        src="/imagenes/florlateral.png"
        alt=""
        id="flor-left"
        class="absolute pointer-events-none"
        style="width: 48px; left: 0; top: 65%; transform: translateY(-50%);"
    />
    <img
        src="/imagenes/florlateral.png"
        alt=""
        id="flor-right"
        class="absolute pointer-events-none"
        style="width: 48px; right: 0; top: 65%; transform: translateY(-50%) scaleX(-1);"
    />

    <div
        class="max-w-sm mx-auto relative z-10 text-center"
        id="contenedor-regalos"
    >
        <!-- Moños flanqueando el título -->
        <div class="flex items-center justify-center gap-3 mb-2">
            <img
                src="/imagenes/mono2.png"
                alt=""
                id="mono-izq"
                style="width: 52px; object-fit: contain;"
            />
            <h3
                class="font-crimson uppercase tracking-[0.2em] text-xl font-semibold"
                style="color: #C9A96E;"
            >
                Sugerencia<br />de Regalo
            </h3>
            <img
                src="/imagenes/mono2.png"
                alt=""
                id="mono-der"
                style="width: 52px; object-fit: contain;"
            />
        </div>

        <!-- Línea decorativa -->
        <div class="flex items-center justify-center gap-3 mb-5">
            <div
                style="width: 50px; height: 1px; background: linear-gradient(to right, transparent, #C9A96E);"
            >
            </div>
            <div
                style="width: 5px; height: 5px; border-radius: 50%; background: #C9A96E; opacity: 0.8;"
            >
            </div>
            <div
                style="width: 50px; height: 1px; background: linear-gradient(to left, transparent, #C9A96E);"
            >
            </div>
        </div>

        <!-- Texto principal -->
        <div id="texto-regalo">
            <p
                class="font-charm text-xl leading-relaxed mb-6"
                style="color: #d0727d;"
            >
                Tu presencia es mi mejor regalo, pero si deseas tener un detalle
                conmigo, puedes hacerlo a través del siguiente QR
            </p>
        </div>

        <!-- QR limpio sin card -->
        <div class="flex justify-center mb-4" id="qr-container">
            <div
                class="rounded-2xl p-3"
                style="border: 2px solid #d0727d33; background: white;"
            >
                <img
                    src="/imagenes/qr.png"
                    alt="Código QR"
                    class="w-52 h-52 object-contain rounded-xl"
                />
            </div>
        </div>

        <!-- Nombre de cuenta debajo del QR -->
        <p class="font-crimson uppercase tracking-widest text-sm mt-3" style="color: #C9A96E; letter-spacing: 0.2em;">Nombre de cuenta</p>
        <p class="font-charm text-xl mt-1 mb-1" style="color: #d0727d;">Libaneza Aramayo Mapatoto</p>

        <!-- Puntos decorativos -->
        <div class="flex justify-center gap-2 mb-4">
            <div
                class="w-1.5 h-1.5 rounded-full"
                style="background: #d0727d; opacity: 0.5;"
            >
            </div>
            <div
                class="w-1.5 h-1.5 rounded-full"
                style="background: #C9A96E; opacity: 0.6;"
            >
            </div>
            <div
                class="w-1.5 h-1.5 rounded-full"
                style="background: #d0727d; opacity: 0.5;"
            >
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initRegalos = () => {
        gsap.set("#contenedor-regalos", { opacity: 0, y: 30 });
        gsap.set("#flor-left", { opacity: 0, x: -30 });
        gsap.set("#flor-right", { opacity: 0, x: 30 });
        gsap.set("#mono-izq", { opacity: 0, x: -15 });
        gsap.set("#mono-der", { opacity: 0, x: 15, scaleX: -1 });

        ScrollTrigger.create({
            trigger: "#contenedor-regalos",
            start: "top 80%",

            onEnter: () => {
                const tl = gsap.timeline();
                tl.to(
                    "#flor-left",
                    { opacity: 0.9, x: 0, duration: 1.2, ease: "power2.out" },
                    0,
                )
                    .to(
                        "#flor-right",
                        {
                            opacity: 0.9,
                            x: 0,
                            duration: 1.2,
                            ease: "power2.out",
                        },
                        0.1,
                    )
                    .to(
                        "#contenedor-regalos",
                        { opacity: 1, y: 0, duration: 1.1, ease: "power2.out" },
                        0.2,
                    )
                    .to(
                        "#mono-izq",
                        {
                            opacity: 1,
                            x: 0,
                            duration: 0.8,
                            ease: "back.out(1.5)",
                        },
                        0.5,
                    )
                    .to(
                        "#mono-der",
                        {
                            opacity: 1,
                            x: 0,
                            scaleX: -1,
                            duration: 0.8,
                            ease: "back.out(1.5)",
                        },
                        0.6,
                    );

                // Balanceo suave moños
                gsap.to("#mono-izq", {
                    rotation: -7,
                    duration: 2.5,
                    repeat: -1,
                    yoyo: true,
                    ease: "sine.inOut",
                    delay: 1.2,
                    transformOrigin: "center top",
                });
                gsap.to("#mono-der", {
                    rotation: -7,
                    scaleX: -1,
                    duration: 2.8,
                    repeat: -1,
                    yoyo: true,
                    ease: "sine.inOut",
                    delay: 1.4,
                    transformOrigin: "center top",
                });
            },

            onLeaveBack: () => {
                gsap.killTweensOf([
                    "#mono-izq",
                    "#mono-der",
                    "#flor-left",
                    "#flor-right",
                ]);
                gsap.to(
                    [
                        "#contenedor-regalos",
                        "#flor-left",
                        "#flor-right",
                        "#mono-izq",
                        "#mono-der",
                    ],
                    {
                        opacity: 0,
                        duration: 0.4,
                        ease: "power2.in",
                    },
                );
            },
        });
    };

    document.addEventListener("DOMContentLoaded", initRegalos);
    document.addEventListener("astro:page-load", initRegalos);
</script>
