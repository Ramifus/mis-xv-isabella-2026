---
// DireccionCeremonia.astro - Recepción
---

<section class="relative w-full py-8 px-6">

    <!-- Separador arriba — borde a borde -->
    <div class="w-full mb-6" style="margin-left: -1.5rem; margin-right: -1.5rem; width: calc(100% + 3rem);">
        <img src="/imagenes/separador.png" alt="" class="w-full object-contain block" />
    </div>

    <!-- Flor izquierda — pegada al borde -->
    <img src="/imagenes/florlateral.png" alt=""
        class="absolute pointer-events-none"
        style="width: 42px; left: 0; top: 50%; transform: translateY(-50%);" />

    <!-- Flor derecha — pegada al borde, espejada -->
    <img src="/imagenes/florlateral.png" alt=""
        class="absolute pointer-events-none"
        style="width: 42px; right: 0; top: 50%; transform: translateY(-50%) scaleX(-1);" />

<div class="max-w-md mx-auto" id="wrapper-ceremonia">
        <div class="text-center opacity-0" id="ceremonia-content">

            <!-- Línea decorativa superior -->
            <div class="flex items-center justify-center gap-3 mb-5">
                <div style="width: 50px; height: 1px; background: linear-gradient(to right, transparent, #C9A96E);"></div>
                <div style="width: 5px; height: 5px; border-radius: 50%; background: #C9A96E; opacity: 0.8;"></div>
                <div style="width: 50px; height: 1px; background: linear-gradient(to left, transparent, #C9A96E);"></div>
            </div>

            <!-- Título -->
            <h3 class="font-crimson uppercase tracking-[0.25em] text-xl font-semibold mb-5"
                style="color: #C9A96E;">
                Recepción Social
            </h3>

            <!-- Ícono con moños -->
            <div class="flex items-center justify-center gap-6 mb-5">
                <!-- Mono izquierdo -->
                <img src="/imagenes/mono2.png" alt=""
                    class="flex-shrink-0 object-contain"
                    style="width: 58px;" />
                <!-- Ícono recepción -->
                <img src="/iconos/recepcion.png" alt="Recepción"
                    class="w-16 h-16 object-contain flex-shrink-0"
                    style="filter: invert(52%) sepia(37%) saturate(614%) hue-rotate(303deg) brightness(96%) contrast(95%);" />
                <!-- Mono derecho (espejado) -->
                <img src="/imagenes/mono2.png" alt=""
                    class="flex-shrink-0 object-contain"
                    style="width: 58px; transform: scaleX(-1);" />
            </div>

            <!-- Nombre del salón -->
            <p class="font-charm text-xl mb-1" style="color: #d0727d;">
                Salón de Eventos Eliane 2
            </p>

            <!-- Dirección -->
            <p class="font-charm text-xl mb-6" style="color: #d0727d; line-height: 1.5;">
                Av. Radiante #13, entre tercer anillo<br />
                externo y cuarto anillo, calle 5
            </p>

            <!-- Línea decorativa -->
            <div class="flex items-center justify-center gap-3 mb-5">
                <div style="width: 50px; height: 1px; background: linear-gradient(to right, transparent, #C9A96E);"></div>
                <div style="width: 5px; height: 5px; border-radius: 50%; background: #C9A96E; opacity: 0.8;"></div>
                <div style="width: 50px; height: 1px; background: linear-gradient(to left, transparent, #C9A96E);"></div>
            </div>

            <!-- Hora y botón -->
            <div class="flex items-center justify-center gap-4">

                <!-- Hora -->
                <div class="rounded-xl px-5 py-2" style="border: 2px solid #d0727d;">
                    <p class="font-charm text-xl font-bold" style="color: #d0727d;">19:00 Hrs.</p>
                </div>

                <!-- Botón mapa -->
                <a href="https://maps.app.goo.gl/cPH7nVTaxtVV8mS86"
                    target="_blank"
                    id="boton-ubicacion"
                    class="font-charm text-xl text-white rounded-xl px-5 py-2 shadow-md transition-all duration-300 hover:opacity-90 active:scale-95"
                    style="background: #d0727d;">
                    Ver ubicación
                </a>
            </div>

        </div>
    </div>

    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        const initCeremonia = () => {
            gsap.set("#ceremonia-content", { opacity: 0, y: 25 });

            ScrollTrigger.create({
                trigger: "#wrapper-ceremonia",
                start: "top 80%",

                onEnter: () => {
                    gsap.to("#ceremonia-content", { opacity: 1, y: 0, duration: 1.1, ease: "power2.out" });
                },

                onLeaveBack: () => {
                    gsap.to("#ceremonia-content", { opacity: 0, y: 25, duration: 0.4, ease: "power2.in" });
                },
            });
        };

        document.addEventListener("DOMContentLoaded", initCeremonia);
        document.addEventListener("astro:page-load", initCeremonia);
    </script>

</section>
